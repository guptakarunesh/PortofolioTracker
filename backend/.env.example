NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DB_PATH=./data/portfolio.db
# Optional: when set, backend uses PostgreSQL (for example Neon) instead of SQLite.
DATABASE_URL=

OTP_PROVIDER=firebase
FIREBASE_WEB_API_KEY=
FIREBASE_TENANT_ID=
FIREBASE_AUTH_BASE_URL=https://identitytoolkit.googleapis.com/v1

PAYMENT_PROVIDER=cashfree
CASHFREE_ENV=sandbox
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_API_VERSION=2023-08-01
CASHFREE_RETURN_URL=
CASHFREE_NOTIFY_URL=
CASHFREE_APP_RETURN_URL=networthmanager://subscription-return

MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
MSG91_BASE_URL=https://control.msg91.com

GUPSHUP_API_KEY=
GUPSHUP_USER_ID=
GUPSHUP_TEMPLATE_ID=
GUPSHUP_SENDER_ID=
GUPSHUP_BASE_URL=https://api.gupshup.io

OTP_EXPIRY_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=30
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6
OTP_COUNTRY_CODE=91
