{
  "expo": {
    "name": "Networth Manager",
    "slug": "indian-portfolio-tracker",
    "scheme": "networthmanager",
    "version": "1.0.0",
    "icon": "./src/assets/app-icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#031a52"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Networth Manager to use Face ID for secure login."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-notifications",
      [
        "expo-video",
        {
          "supportsPictureInPicture": true
        }
      ]
    ],
    "ios": {
      "icon": "./src/assets/app-icon.png",
      "bundleIdentifier": "com.networthmanager.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "usesNonExemptEncryption": false
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.networthmanager.app",
      "googleServicesFile": "./google-services.json",
      "icon": "./src/assets/app-icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#031a52"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "3c237618-49f6-47e7-b951-abe8f408c5ba"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3c237618-49f6-47e7-b951-abe8f408c5ba"
    }
  }
}
