{
  "cli": {
    "version": ">= 18.1.0"
  },
  "build": {
    "preview": {
      "environment": "preview",
      "channel": "preview",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preprod": {
      "environment": "preview",
      "channel": "preprod",
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://portofoliotracker-preprod.onrender.com"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "environment": "production",
      "channel": "production"
    }
  }
}
